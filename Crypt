const Analytics = {
  bookCombined: function(sym){
    const use = String(readSettingMap()['USE_BOOK']||'true')==='true';
    if(!use) return null;
    var asks=[], bids=[], srcs=[];
    try{
      const ok = dataManager.okxBook(sym);
      if(ok && ok.data && ok.data[0]){
        const d=ok.data[0];
        asks=asks.concat((d.asks||[]).map(function(a){return [+a[0],+a[1]];}).slice(0,BOOK_LEVELS));
        bids=bids.concat((d.bids||[]).map(function(b){return [+b[0],+b[1]];}).slice(0,BOOK_LEVELS));
        srcs.push('OKX');
      }
    }catch(e){}
    try{
      const bn = dataManager.binanceBook(sym);
      if(bn){
        asks=asks.concat((bn.asks||[]).map(function(a){return [+a[0],+a[1]];}).slice(0,BOOK_LEVELS));
        bids=bids.concat((bn.bids||[]).map(function(b){return [+b[0],+b[1]];}).slice(0,BOOK_LEVELS));
        srcs.push('BINANCE');
      }
    }catch(e){}
    if(!asks.length && !bids.length) return null;
    asks.sort(function(a,b){return a[0]-b[0];});
    bids.sort(function(a,b){return b[0]-a[0];});
    return {src:srcs.join('|')||'N/A', asks:asks, bids:bids};
  },
  wallsAndObi: function(sym, mid){
    const book = Analytics.bookCombined(sym);
    if(!book) return { OBI:0, floor:null, ceil:null, src:'N/A' };
    const asks=book.asks.slice(0,BOOK_LEVELS), bids=book.bids.slice(0,BOOK_LEVELS);
    const askVol=U.sum(asks.map(function(a){return a[1];})), bidVol=U.sum(bids.map(function(b){return b[1];}));
    const OBI = (bidVol-askVol)/Math.max(1e-9, (bidVol+askVol));

    const avgAsk = asks.length? U.mean(asks.map(function(a){return a[1];})) : 0;
    const avgBid = bids.length? U.mean(bids.map(function(b){return b[1];})) : 0;
    const askThr = avgAsk * WALL_REL_MULT;
    const bidThr = avgBid * WALL_REL_MULT;

    var ceil=null, floor=null;
    for(var i=0;i<asks.length;i++){ var p=asks[i][0], sz=asks[i][1]; if(sz>=askThr && p>mid){ ceil = p; break; } }
    for(var j=0;j<bids.length;j++){ var pb=bids[j][0], szb=bids[j][1]; if(szb>=bidThr && pb<mid){ floor = pb; break; } }
    return { OBI:OBI, floor:floor, ceil:ceil, src:book.src };
  },
  cvd: function(sym){
    const use = String(readSettingMap()['USE_TRADES']||'true')==='true';
    if(!use) return 0;
    try{
      const ok = dataManager.okxTrades(sym, 120);
      if(ok && ok.data){
        var s=0;
        for(var i=0;i<ok.data.length;i++){
          const t=ok.data[i];
          const sz=+t.sz; const side=String(t.side||'').toLowerCase();
          if(!isFinite(sz)) continue;
          s += (side==='buy'? +sz : (side==='sell'? -sz : 0));
        }
        return s;
      }
    }catch(e){}
    try{
      const bn = dataManager.binanceTrades(sym, 200);
      if(Array.isArray(bn)){
        var s2=0;
        for(var k=0;k<bn.length;k++){
          const t2=bn[k]; const qty=+t2.qty; const isBuyerMaker=!!t2.isBuyerMaker;
          s2 += (isBuyerMaker? -qty : +qty);
        }
        return s2;
      }
    }catch(e){}
    return 0;
  },
  funding: function(sym){
    const use = String(readSettingMap()['USE_OI_FUND']||'true')==='true';
    if(!use) return 0;
    try{
      const r = dataManager.funding(sym);
      if(r && r.data && r.data[0]) return +r.data[0].fundingRate || 0;
    }catch(e){}
    return 0;
  },
  openInterest: function(sym){
    const use = String(readSettingMap()['USE_OI_FUND']||'true')==='true';
    if(!use) return { oi:0, delta:0 };
    const props = U.props(); const key = 'OI_LAST_'+sym;
    try{
      const r = dataManager.openInterest(sym);
      if(r && r.data && r.data[0]){
        const oi = +r.data[0].oi || 0;
        const prev = +(props.getProperty(key) || '0');
        props.setProperty(key, String(oi));
        return { oi:oi, delta: oi - prev };
      }
    }catch(e){}
    return { oi:0, delta:0 };
  },
  atr: function(sym){
    const use = String(readSettingMap()['USE_OHLC']||'true')==='true';
    if(!use) return 0;
    try{
      const r = dataManager.ohlc1m(sym, Math.max(ATR_PERIOD_M1+5, 60));
      if(r && r.data){
        const rows = r.data.map(function(a){return {o:+a[1], h:+a[2], l:+a[3], c:+a[4]};}).reverse();
        if(rows.length<ATR_PERIOD_M1+1) return 0;
        const tr=[];
        for(var i=1;i<rows.length;i++){
          const hi=rows[i].h, lo=rows[i].l, pc=rows[i-1].c;
          tr.push(Math.max(hi-lo, Math.abs(hi-pc), Math.abs(lo-pc)));
        }
        const n=ATR_PERIOD_M1;
        const atr = tr.slice(-n).reduce(function(s,x){return s+x;},0)/n;
        return atr;
      }
    }catch(e){}
    return 0;
  },
  horizonByProj: function(px, floor, ceil){
    const up = isFinite(ceil)? (ceil - px) : Infinity;
    const dn = isFinite(floor)? (px - floor) : Infinity;
    const dist = Math.min(up, dn);
    const pct = dist/px;
    if(pct <= 0.004) return 'SCALP';
    if(pct <= 0.02)  return 'SWING';
    return 'POSITION';
  },
  btcAdj: function(sym){
    if(sym==='BTC') return 0;
    const sh = U.getOrCreate('📈 ДЕРИВАТИВЫ', ['Время (MSK)','Символ','Цена','Источник','UTC','MSK ISO','Freshness']);
    const rng = sh.getDataRange().getValues();
    const rows = rng.slice(1).filter(function(r){return r[1] && r[2];});
    const takeN=200;
    const pxBySym = {};
    for(var i=Math.max(0, rows.length-takeN); i<rows.length; i++){
      const r=rows[i], s=String(r[1]), p=+r[2];
      if(!isFinite(p)) continue;
      if(!pxBySym[s]) pxBySym[s]=[];
      pxBySym[s].push(p);
    }
    const sArr = pxBySym[sym]||[];
    const bArr = pxBySym['BTC']||[];
    const n = Math.min(sArr.length, bArr.length);
    if(n<30) return 0;
    function logret(a){ const out=[]; for(var i2=1;i2<a.length;i2++){ if(a[i2-1]>0) out.push(Math.log(a[i2]/a[i2-1])); } return out; }
    const rS = logret(sArr).slice(-100);
    const rB = logret(bArr).slice(-100);
    const corr = U.corr(rS, rB);
    var adj = corr*0.12;
    if(adj>0.12) adj=0.12; if(adj<-0.12) adj=-0.12;
    return adj;
  }
};

