function calcSL_TPs(side, px, atr, floor, ceil, eventSLmult){
  const atrSL = Math.max(atr, px * (+readSettingMap()['ATR_MIN_RATIO'] || ATR_MIN_RATIO));
  const buf   = px * (+readSettingMap()['WALL_BUF_RATIO'] || WALL_BUF_RATIO);
  var SL=null;
  if(side==='LONG'){
    SL = isFinite(floor)? (floor - buf) : (px - atrSL);
  }else{
    SL = isFinite(ceil)? (ceil + buf)  : (px + atrSL);
  }
  if(eventSLmult && isFinite(eventSLmult) && eventSLmult>0.1) {
    if(side==='LONG') SL = px - (px - SL)*eventSLmult;
    else              SL = px + (SL - px)*eventSLmult;
  }
  const R = Math.abs(px - SL);
  const TPs = TP_R.map(function(r){ return side==='LONG'? (px + r*R) : (px - r*R); });
  return { SL:SL, TPs:TPs, R:R };
}
