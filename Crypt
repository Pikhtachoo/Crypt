  clamp(x,a,b){ return Math.max(a, Math.min(b,x)); },
  sigmoid(z){ return 1/(1+Math.exp(-z)); },
  zScore(x, mean, std){ return std>0? (x-mean)/std : 0; },
  sum(a){ return a.reduce((s,x)=>s+(+x||0),0); },
  mean(a){ return a.length? U.sum(a)/a.length : 0; },
  std(a){
    if(a.length<2) return 0;
    const m=U.mean(a); const v=U.mean(a.map(x=>(x-m)*(x-m)));
    return Math.sqrt(v);
  },
  corr(a,b){
    const n=Math.min(a.length,b.length); if(n<3) return 0;
    const x=a.slice(-n), y=b.slice(-n);
    const mx=U.mean(x), my=U.mean(y);
    let num=0, dx=0, dy=0;
    for(let i=0;i<n;i++){ const vx=x[i]-mx, vy=y[i]-my; num+=vx*vy; dx+=vx*vx; dy+=vy*vy; }
    return (dx>0 && dy>0)? (num/Math.sqrt(dx*dy)) : 0;
  },
  id(sym){ return 'QTP-'+Date.now()+'-'+sym; },
  toFixedDyn(p){
