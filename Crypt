function computeFeatures(sym, snap){
  const walls = Analytics.wallsAndObi(sym, snap.price);
  const atr   = Analytics.atr(sym);
  const cvd   = Analytics.cvd(sym);
  const fRate = Analytics.funding(sym);
  const oiObj = Analytics.openInterest(sym);
  const oi = oiObj.oi, delta = oiObj.delta;
  const projDist = (function(){
    const up = isFinite(walls.ceil)? (walls.ceil - snap.price) : 0;
    const dn = isFinite(walls.floor)? (snap.price - walls.floor) : 0;
    const d = Math.max(up, dn);
    return d>0? (d/snap.price) : 0;
  })();
  const btcAdj = Analytics.btcAdj(sym);
  return {
    OBI: walls.OBI||0,
    floor: walls.floor, ceil: walls.ceil,
    atr: atr, cvd: cvd || 0,
    funding: fRate || 0,
    oi: oi, dOI: delta || 0,
    proj: projDist,
    btcAdj: btcAdj
  };
}
function decideHorizon(px, floor, ceil){
