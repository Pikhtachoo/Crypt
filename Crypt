function ensureModelSheet(){
  const sh = U.getOrCreate('🧠 МОДЕЛЬ', ['Feature','Weight']);
  const defaults = [
    ['bias',  -0.10],
    ['OBI',    0.80],
    ['Funding',-0.50],
    ['dOI',    0.35],
    ['CVD',    0.20],
    ['Proj',   0.60],
    ['H_SCALP', 0.10],
    ['H_SWING', 0.05],
    ['H_POSITION', -0.05],
    ['BTCadj', 0.50]
  ];
  if(sh.getLastRow()<defaults.length+1){
    sh.getRange(2,1,defaults.length,2).setValues(defaults);
  }
  return sh;
}
function readWeights(){
  const sh = ensureModelSheet();
  const n=sh.getLastRow()-1; const rows = n>0? sh.getRange(2,1,n,2).getValues() : [];
  const w={}; rows.forEach(function(rv){ w[String(rv[0])] = +rv[1]; });
  return w;
}
function writeWeights(w){
  const sh=ensureModelSheet(); const n=sh.getLastRow()-1; const rows=sh.getRange(2,1,n,1).getValues();
  const out=[]; for(var i=0;i<rows.length;i++){ const k=String(rows[i][0]); out.push([ isFinite(w[k])? w[k] : 0 ]); }
  sh.getRange(2,2,out.length,1).setValues(out);
}
function modelScore(features, horizonTag){
  const w=readWeights();
  const z =
    (w.bias||0) +
    (w.OBI||0)*features.OBI +
    (w.Funding||0)*features.funding +
    (w.dOI||0)*features.dOI +
    (w.CVD||0)*features.cvd +
    (w.Proj||0)*features.proj +
    (w.BTCadj||0)*features.btcAdj +
    (horizonTag==='SCALP'   ? (w.H_SCALP||0)   : 0) +
    (horizonTag==='SWING'   ? (w.H_SWING||0)   : 0) +
    (horizonTag==='POSITION'? (w.H_POSITION||0): 0);
  return U.sigmoid(z);
}
function modelOnlineUpdate(example){
  const w=readWeights();
  const lr=+readSettingMap()['LR']||LR;
  const l2=+readSettingMap()['L2']||L2;
  const y = example.label;
  const p = example.prob;
  const y01 = (y+1)/2;
  const g = (p - y01);
  function upd(k, xk){ w[k] = (w[k]||0) - lr * ( g * xk + l2*(w[k]||0) ); }
  upd('bias', 1);
  upd('OBI', example.feats.OBI||0);
  upd('Funding', example.feats.funding||0);
  upd('dOI', example.feats.dOI||0);
  upd('CVD', example.feats.cvd||0);
  upd('Proj', example.feats.proj||0);
  upd('BTCadj', example.feats.btcAdj||0);
  upd('H_SCALP',   example.horizon==='SCALP'?1:0);
  upd('H_SWING',   example.horizon==='SWING'?1:0);
  upd('H_POSITION',example.horizon==='POSITION'?1:0);
  writeWeights(w);
}

