/* ====== Throttled /pack (anti-quota) ====== */
function _throttledPack(symbols){
  const cache = U.cache(), props = U.props();
  const key = 'PACK_LAST_JSON'; const tKey = 'PACK_LAST_TS'; const lockKey = 'PACK_LOCK';
  const cached = cache.get(key); const cachedTs = Number(props.getProperty(tKey) || '0');
  const now = Date.now();
  var rl = Number(readSettingMap()['PACK_RATE_LIMIT_MS'] || PACK_RATE_LIMIT_MS);

  if (cached && (now - cachedTs) < rl) {
    const obj = U.readJsonSafe(cached); if (obj && obj.ok) return Object.assign({}, obj, {_source:'LIVE'});
  }
  if(!props.getProperty(lockKey)){
    try{
      props.setProperty(lockKey, String(now));
      const resp = WorkerClient.getPack(symbols);
      cache.put(key, JSON.stringify(resp), PACK_CACHE_TTL_SEC);
      props.setProperty(tKey, String(now));
      props.deleteProperty(lockKey);
      return Object.assign({}, resp, {_source:'LIVE'});
    }catch(e){
      props.deleteProperty(lockKey);
      if(cached){ const obj = U.readJsonSafe(cached); if(obj && obj.ok) return Object.assign({}, obj, {_source:'STALE', _error:String(e && e.message || e)}); }
      throw e;
    }
  }else{
    if(cached){ const obj = U.readJsonSafe(cached); if(obj && obj.ok) return Object.assign({}, obj, {_source: (now-cachedTs)<rl? 'LIVE':'STALE'}); }
    const resp2 = WorkerClient.getPack(symbols);
    cache.put(key, JSON.stringify(resp2), PACK_CACHE_TTL_SEC);
    props.setProperty(tKey, String(now));
    return Object.assign({}, resp2, {_source:'LIVE'});
  }
}

/* ====== Generic cached fetch (books/trades/funding/oi/ohlc) ====== */
function _cachedJson(key, ttlSec, rateMs, urlBuildFn){
  const cache = U.cache(), props = U.props();
  const dataKey = 'C_'+key, tsKey = 'T_'+key, lockKey='L_'+key;
  const cached = cache.get(dataKey); const lastTs = Number(props.getProperty(tsKey)||'0'); const now=Date.now();

  if(cached && (now-lastTs) < rateMs){ const obj=U.readJsonSafe(cached); if(obj) return obj; }
  if(!props.getProperty(lockKey)){
    try{
      props.setProperty(lockKey, String(now));
      const uo = urlBuildFn();
      const url = uo.url; const headers = uo.headers || {};
      const r = UrlFetchApp.fetch(url, { muteHttpExceptions:true, followRedirects:true, headers: headers });
      if(r.getResponseCode()!==200) throw new Error('status '+r.getResponseCode());
      const obj = JSON.parse(r.getContentText());
      cache.put(dataKey, JSON.stringify(obj), ttlSec);
      props.setProperty(tsKey, String(now));
      props.deleteProperty(lockKey);
      return obj;
    }catch(e){
      props.deleteProperty(lockKey);
      if(cached){ const obj=U.readJsonSafe(cached); if(obj) return obj; }
      throw e;
    }
  }else{
    if(cached){ const obj=U.readJsonSafe(cached); if(obj) return obj; }
    const uo2 = urlBuildFn();
    const r2 = UrlFetchApp.fetch(uo2.url, { muteHttpExceptions:true, followRedirects:true, headers: (uo2.headers||{}) });
    if(r2.getResponseCode()!==200) throw new Error('status '+r2.getResponseCode());
    const obj2 = JSON.parse(r2.getContentText());
    cache.put(dataKey, JSON.stringify(obj2), ttlSec);
    props.setProperty(tsKey, String(now));
    return obj2;
  }
}

